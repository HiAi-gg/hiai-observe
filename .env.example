# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  HiAi Observe — Configuration Template                                  ║
# ║  Copy to .env and fill in your values.                                  ║
# ║  NEVER commit .env to git — only .env.example is tracked.               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://hiai_observe:your_password@localhost:5433/hiai_observe

# ── Cache / Pub-Sub ────────────────────────────────────────────────────────
# Redis connection string (rate limiting, alert dedup, log pub/sub)
# Use redis://:password@host:port for password-protected Redis
REDIS_URL=redis://localhost:6380

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8001
NODE_ENV=development
LOG_LEVEL=info

# ── Authentication ──────────────────────────────────────────────────────────
# API key for Bearer auth. Generate: bun run gen-key
HIAI_OBSERVE_API_KEY=your-secret-api-key-here

# ── CORS ────────────────────────────────────────────────────────────────────
# false = no CORS, or URL like http://localhost:5173
CORS_ORIGIN=false

# ── Docker Monitoring ───────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
COLLECTION_INTERVAL_MS=30000
CONTAINER_INCLUDE=
CONTAINER_EXCLUDE=

# ── Notifications: Telegram ─────────────────────────────────────────────────
# Get bot token: https://t.me/BotFather
# Get chat ID: send message to bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notifications: Discord ──────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── Notifications: Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── External Health Ping ───────────────────────────────────────────────────
# URL to ping every 60s with health status (Uptime Kuma, Healthchecks.io, etc.)
# Leave empty to disable
HEALTH_PING_URL=

# ── Data Retention ──────────────────────────────────────────────────────────
RETENTION_DAYS=30

# ── Admin API ───────────────────────────────────────────────────────────────
# Admin API key for management endpoints (user CRUD, project management)
ADMIN_API_KEY=

# ── Notification Encryption ─────────────────────────────────────────────────
# AES-256-GCM key for encrypting notification tokens at rest in the database.
# Generate with: openssl rand -hex 32
# If not set, notification credentials are stored as plaintext.
ENCRYPTION_KEY=
