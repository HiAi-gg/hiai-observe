# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  HiAi Observe — Configuration Template                                  ║
# ║  Copy to .env and fill in your values.                                  ║
# ║  NEVER commit .env to git — only .env.example is tracked.               ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://hiai_observe:your_password@localhost:5433/hiai_observe

# ── Cache / Pub-Sub ────────────────────────────────────────────────────────
# Redis connection string (rate limiting, alert dedup, log pub/sub)
# Use redis://:password@host:port for password-protected Redis
REDIS_URL=redis://localhost:6380

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8001
NODE_ENV=development
LOG_LEVEL=info

# ── Authentication ──────────────────────────────────────────────────────────
# Bootstrap API key. On startup the server provisions a "Default" admin project
# whose hashed key matches this value, so a fresh install is usable immediately.
# Use it as a Bearer token / Sentry DSN. Set a long random value in production:
#   openssl rand -hex 24   (optionally prefix with "ho_")
# Leave blank to manage keys only via the UI / `bun run gen-key`.
HIAI_OBSERVE_API_KEY=your-secret-api-key-here

# ── CORS ────────────────────────────────────────────────────────────────────
# false = no CORS, or URL like http://localhost:5173
CORS_ORIGIN=false

# ── Docker Monitoring ───────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
# Docker Engine API version. Leave blank to use the versionless path (the daemon
# serves its current API) — recommended. Pin only if needed, e.g. 1.44. Modern
# daemons reject versions below their MinAPIVersion (Docker 29 = 1.44).
DOCKER_API_VERSION=
COLLECTION_INTERVAL_MS=30000
CONTAINER_INCLUDE=
CONTAINER_EXCLUDE=

# ── Notifications: Telegram ─────────────────────────────────────────────────
# Get bot token: https://t.me/BotFather
# Get chat ID: send message to bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notifications: Discord ──────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── Notifications: Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── External Health Ping ───────────────────────────────────────────────────
# URL to ping every 60s with health status (Uptime Kuma, Healthchecks.io, etc.)
# Leave empty to disable
HEALTH_PING_URL=

# ── Log Streaming ───────────────────────────────────────────────────────────
# Per-container log rate limiting (0 = unlimited). Default 1000 lines/sec.
# For small VPS (<512MB RAM): set to 100 to prevent memory exhaustion.
LOG_MAX_LINES_PER_SEC=1000
# Max entries in memory before backpressure (0 = unlimited). Default 10000.
# For small VPS: set to 1000 to keep memory usage low.
LOG_MAX_BUFFER_SIZE=10000
# Batch flush interval in milliseconds. Default 500ms.
# For small VPS: set to 2000 to reduce DB write frequency.
LOG_BATCH_INTERVAL_MS=500
# Fraction of logs to keep, 0.0-1.0 (1.0 = keep all). Default 1.0.
# For small VPS: set to 0.1 to keep only 10% of logs.
LOG_SAMPLE_RATE=1.0
# Max concurrent DB insert promises (0 = unlimited). Default 3.
# For small VPS: set to 1 to serialize DB writes.
LOG_MAX_CONCURRENT_INSERTS=3
# Comma-separated container name patterns to include in log streaming.
LOG_INCLUDE_CONTAINERS=
# Comma-separated container name patterns to exclude from log streaming.
LOG_EXCLUDE_CONTAINERS=

# ── Data Retention ──────────────────────────────────────────────────────────
RETENTION_DAYS=30

# ── AI Cost Estimation ──────────────────────────────────────────────────────
# Override per-model LLM pricing (USD per 1M tokens) used for trace cost
# estimates. JSON map of model -> { "prompt": <in>, "completion": <out> },
# merged over the built-in defaults. List prices drift — set this to keep cost
# accurate for the models you actually run.
#   MODEL_PRICING={"claude-sonnet-4":{"prompt":3,"completion":15}}
MODEL_PRICING=

# ── Admin API ───────────────────────────────────────────────────────────────
# Admin API key for management endpoints (user CRUD, project management)
ADMIN_API_KEY=

# ── Notification Encryption ─────────────────────────────────────────────────
# AES-256-GCM key for encrypting notification tokens at rest in the database.
# Generate with: openssl rand -hex 32
# If not set, notification credentials are stored as plaintext.
ENCRYPTION_KEY=
