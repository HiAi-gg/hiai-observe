# HiAi Observe Configuration
# Copy to .env and fill in your values

# ── Required ──────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://observe:observe@localhost:5432/hiai_observe

# ── Optional ──────────────────────────────────────────────────────────────
# Redis connection string (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# API server port (default: 8001)
PORT=8001

# Environment: development | production
NODE_ENV=development

# Default API key for testing (generate real keys with: bun run gen-key)
HIAI_OBSERVE_API_KEY=your-secret-api-key-here

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Docker socket path (for container monitoring)
DOCKER_SOCKET=/var/run/docker.sock

# CORS origin (false = no CORS, or specific origin URL)
CORS_ORIGIN=false

# ── Notifications (optional) ──────────────────────────────────────────────
# Telegram bot for alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=

# SMTP for email alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
